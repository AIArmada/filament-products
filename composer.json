{
    "name": "aiarmada/filament-products",
    "description": "Filament admin panel for product catalog management",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "products",
        "admin",
        "commerce"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/products": "self.version",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "filament/spatie-laravel-tags-plugin": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentProducts\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentProducts\\FilamentProductsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}